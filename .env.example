# =============================================================================
# NOVA Glass — Variables de Entorno
# =============================================================================
# Copia este archivo a .env y ajusta los valores según tu entorno.
# Las variables de entorno tienen prioridad sobre config.json / config.local.json
# =============================================================================

# --- Hub / Conexión ---------------------------------------------------------
NOVA_HUB=http://127.0.0.1:8080        # URL del hub NOVA Glass
NOVA_NODE=spark01                     # Nombre del nodo (default: hostname)
NOVA_TOKEN=                           # Token de ingesta (requerido en prod)

# --- LLM (NOVA Insights) ----------------------------------------------------
LLM_BASE_URL=http://127.0.0.1:8003/v1  # URL del endpoint vLLM / OpenAI-compatible
LLM_MODEL=deepseek-v4-flash             # Modelo a usar
LLM_API_KEY=none                        # API key (opcional si el endpoint no requiere auth)
LLM_TEMPERATURE=0.3                     # Temperatura para inferencia
LLM_TIMEOUT=180                         # Timeout en segundos

# --- Base de datos ----------------------------------------------------------
NOVA_DB_FILE=data/nova.db              # Ruta al archivo SQLite

# --- Intervalos de recolección ----------------------------------------------
NOVA_FAST_INTERVAL=5                   # Loop rápido (segundos) — CPU, mem, GPU
NOVA_SLOW_INTERVAL=300                 # Loop lento (segundos) — discos, apt, containers
NOVA_DEVICE_INTERVAL=30                # Intervalo de probes a dispositivos (segundos)

# --- Umbrales de alerta -----------------------------------------------------
THRESHOLD_CPU_PCT=92
THRESHOLD_MEM_PCT=92
THRESHOLD_SWAP_PCT=60
THRESHOLD_DISK_PCT=85
THRESHOLD_GPU_TEMP=88
THRESHOLD_ANOMALY_Z=4.0
THRESHOLD_SUSTAINED_SAMPLES=4

# --- Docker / Container -----------------------------------------------------
TZ=America/Mexico_City                 # Zona horaria del contenedor

# --- Webhooks ---------------------------------------------------------------
# WEBHOOK_TELEGRAM_BOT_TOKEN=tu_bot_token
# WEBHOOK_TELEGRAM_CHAT_ID=tu_chat_id
# WEBHOOK_GENERIC_URL=https://tu-endpoint/webhook/nova
